# ============================================
# AI Subtitle Generator Platform
# Copy this file to .env and fill in the values
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2 (S3-compatible)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=subtitle-platform
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Groq (ASR / Speech-to-Text)
GROQ_API_KEY=your-groq-api-key

# Gemini (Translation)
GEMINI_API_KEY=

# Sarvam (Voice Cloning)
SARVAM_API_KEY=your-gemini-api-key

# Upstash (Job Queue)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
UPSTASH_QSTASH_TOKEN=your-qstash-token
QSTASH_URL=https://qstash-us-east-1.upstash.io
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# Backend URL (used by QStash to call workers)
BACKEND_URL=https://your-backend.onrender.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
